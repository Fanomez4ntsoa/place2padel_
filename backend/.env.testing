# ------------------------------------------------------------------
# Environnement testing — chargé par Laravel quand APP_ENV=testing
# (phpunit.xml force APP_ENV=testing). Laravel lit ce fichier AU LIEU
# de .env, donc toutes les valeurs nécessaires sont répétées ici.
#
# Fix le leak rate-limiter + MilestoneTest : CACHE_STORE et
# QUEUE_CONNECTION doivent être "array"/"sync" (non pas redis),
# MAIL_MAILER doit être "array" (Resend domain non vérifié en dev
# faisait throw la chaîne sync FanoutJob → SendEmailJob).
# ------------------------------------------------------------------

APP_NAME=Place2Padel
APP_ENV=testing
APP_KEY=base64:tt8M1FRCbUnJGLsd41lrYESt8LHqfs4D9S5h47CAYrA=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=place2padel_test
DB_USERNAME=admin
DB_PASSWORD=admin2025

# Pas de persistence externe en tests — tout en mémoire / sync.
BCRYPT_ROUNDS=4
CACHE_STORE=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
MAIL_MAILER=array
BROADCAST_CONNECTION=null
FILESYSTEM_DISK=local
# AVATAR_DISK volontairement omis : tests/Feature/User/UploadProfilePhotoTest
# hardcode `Storage::fake('s3')` et lit depuis le même disque. Laisse le
# default config filesystems.avatars = env('AVATAR_DISK', 's3') = 's3'.

# Désactivé : Telescope/Pulse/Nightwatch monopolisent la DB en tests.
PULSE_ENABLED=false
TELESCOPE_ENABLED=false
NIGHTWATCH_ENABLED=false

# Sanctum — stateless forcé (cohérent TestCase::setUp).
SANCTUM_STATEFUL_DOMAINS=
