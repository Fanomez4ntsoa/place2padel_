APP_NAME=Place2Padel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=place2padel
DB_USERNAME=root
DB_PASSWORD=

CACHE_STORE=redis
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=resend
MAIL_FROM_ADDRESS="hello@place2padel.com"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=

AWS_ACCESS_KEY_ID=        # Access Key IONOS S3
AWS_SECRET_ACCESS_KEY=    # Secret Key IONOS S3
AWS_DEFAULT_REGION=       # ex: eu-central-1
AWS_BUCKET=               # nom de ton bucket
AWS_ENDPOINT=             # ex: https://s3.eu-central-1.ionoscloud.com
AWS_USE_PATH_STYLE_ENDPOINT=true  # obligatoire pour IONOS

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/api/v1/auth/google/callback"

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

FRONTEND_URL=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=localhost:3000

VITE_APP_NAME="${APP_NAME}"
